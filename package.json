{
  "name": "missav-manager",
  "version": "2.16.0",
  "description": "MissAV 收藏管理桌面工具 — 番号 → MissAV 元数据抓取 → Raindrop 导入文件生成",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/3ll3-3ll3/missav-manager.git"
  },
  "bugs": {
    "url": "https://github.com/3ll3-3ll3/missav-manager/issues"
  },
  "homepage": "https://github.com/3ll3-3ll3/missav-manager#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "build:portable": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win portable"
  },
  "build": {
    "appId": "com.wjl.missav-manager",
    "productName": "MissAV_Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "src/**",
      "assets/**",
      "node_modules/**"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "MissAV_Manager_v${version}.exe"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "author": "WJL",
  "license": "MIT"
}
